const { execSync } = require('child_process');
try {
  const output = execSync('python -m pytest tests/test_pdf_export.py -v --tb=short 2>&1', { 
    cwd: 'C:\\Users\\April\\Desktop\\cosmic-script',
    encoding: 'utf-8',
    timeout: 30000
  });
  require('fs').writeFileSync('C:\\Users\\April\\Desktop\\cosmic-script\\test_results.txt', output);
  console.log(output);
} catch (e) {
  const output = e.stdout || e.stderr || e.message;
  require('fs').writeFileSync('C:\\Users\\April\\Desktop\\cosmic-script\\test_results.txt', output);
  console.log(output);
}
