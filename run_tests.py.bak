"""Quick test runner for PDF typography tests."""

import subprocess
import sys

result = subprocess.run(
    [sys.executable, "-m", "pytest", "tests/test_pdf_export.py", "-v", "--tb=short"],
    capture_output=True,
    text=True,
    cwd=r"C:\Users\April\Desktop\cosmic-script",
)

print("STDOUT:")
print(result.stdout)
print("\nSTDERR:")
print(result.stderr)
print(f"\nReturn code: {result.returncode}")
